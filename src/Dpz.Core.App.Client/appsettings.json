{
  "ApiSettings": {
    "BaseAddress": "https://api.example.com",
    "OIDC": {
      "ClientId": "dpz.client",
      "Authority": "https://localhost:7183",
      "ResponseType": "code",
      "ResponseMode": "query",
      "RedirectUri": "dpz-client://auth",
      "Scopes": "openid profile offline_access",
      "ConfigEndpoint": "/.well-known/openid-configuration"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  }
}