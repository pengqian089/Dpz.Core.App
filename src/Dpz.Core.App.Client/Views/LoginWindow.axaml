<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Dpz.Core.App.Client.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="Dpz.Core.App.Client.Views.LoginWindow"
        x:DataType="vm:LoginWindowViewModel"
        Title="Dpz Core 管理平台 - 登录"
        Icon="/Assets/logo.ico"
        Width="1000" Height="600"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True">

    <Window.Styles>
        <StyleInclude Source="/Styles/LoginStyles.axaml"/>
    </Window.Styles>

    <!-- 渐变背景 -->
    <Panel>
        <!-- 动态渐变背景 -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#667eea" Offset="0"/>
                    <GradientStop Color="#764ba2" Offset="0.5"/>
                    <GradientStop Color="#f093fb" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- 装饰圆圈 -->
        <Canvas>
            <!-- 左上角大圆 -->
            <Ellipse Width="300" Height="300" 
                     Canvas.Left="-100" Canvas.Top="-100"
                     Opacity="0.1">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            
            <!-- 右下角大圆 -->
            <Ellipse Width="400" Height="400" 
                     Canvas.Right="-150" Canvas.Bottom="-150"
                     Opacity="0.1">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- 中间小圆 -->
            <Ellipse Width="150" Height="150" 
                     Canvas.Left="200" Canvas.Top="100"
                     Opacity="0.08">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <!-- 主登录卡片 -->
        <Border Classes="LoginCard"
                Width="450" Height="550"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            
            <StackPanel Spacing="25" Margin="50,40">
                
                <!-- Logo 和标题区域 -->
                <StackPanel Spacing="15" HorizontalAlignment="Center">
                    <!-- Logo 圆形 -->
                    <Border Width="80" Height="80" 
                            CornerRadius="40"
                            Background="#764ba2"
                            BoxShadow="0 4 15 0 #40000000">
                        <Image Source="/Assets/logo.png" 
                               Width="50" Height="50"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- 标题 -->
                    <TextBlock Text="Dpz Core 管理平台" 
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="使用 OIDC 安全登录" 
                               FontSize="14"
                               Foreground="#E0FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 错误提示 -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF6B6B"
                           FontSize="13"
                           TextAlignment="Center"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- 登录按钮 -->
                <Button Classes="LoginButton"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding CanLogin}"
                        Height="50"
                        Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" 
                                Spacing="12"
                                HorizontalAlignment="Center">
                        <TextBlock Text="&#xf2f6;" 
                                   FontFamily="{StaticResource FontAwesomeSolid}"
                                   FontSize="18"
                                   IsVisible="{Binding !IsLoading}"/>
                        <TextBlock Text="OIDC 登录" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   IsVisible="{Binding !IsLoading}"/>
                        <TextBlock Text="登录中..." 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   IsVisible="{Binding IsLoading}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 右上角按钮组 -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Spacing="10"
                    Margin="20">
            
            <!-- 设置按钮 -->
            <Button Width="40" Height="40"
                    Background="#20FFFFFF"
                    BorderThickness="0"
                    CornerRadius="20"
                    Command="{Binding ShowSettingsCommand}"
                    Cursor="Hand">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </Style>
                </Button.Styles>
                <TextBlock Text="&#xf013;" 
                           FontFamily="{StaticResource FontAwesomeSolid}"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            
                <!-- 关闭按钮 -->
            <Button Classes="CloseButton"
                    Command="{Binding CancelCommand}">
                <TextBlock Text="&#xf00d;" 
                           FontFamily="{StaticResource FontAwesomeSolid}"
                           FontSize="16"/>
            </Button>
        </StackPanel>
    </Panel>
</Window>
