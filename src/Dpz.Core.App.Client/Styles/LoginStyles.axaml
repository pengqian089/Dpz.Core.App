<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 登录卡片样式 -->
    <Style Selector="Border.LoginCard">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BoxShadow" Value="0 20 60 0 #60000000"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 输入框包装样式 -->
    <Style Selector="Border.InputWrapper">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.25"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.3"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- 输入框包装悬停状态 -->
    <Style Selector="Border.InputWrapper:pointerover">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.22"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 输入框获取焦点状态 -->
    <Style Selector="Border.InputWrapper:focus-within">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.25"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 登录输入框样式 -->
    <Style Selector="TextBox.LoginInput">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0,0,10,0"/>
        <Setter Property="CaretBrush" Value="White"/>
    </Style>

    <!-- 输入框水印文字样式 -->
    <Style Selector="TextBox.LoginInput /template/ TextBlock#PART_PlaceholderText">
        <Setter Property="Foreground" Value="#A0FFFFFF"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 复选框样式 -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- 登录按钮样式 -->
    <Style Selector="Button.LoginButton">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#f093fb" Offset="0"/>
                    <GradientStop Color="#f5576c" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- 登录按钮悬停效果 -->
    <Style Selector="Button.LoginButton:pointerover">
        <Setter Property="RenderTransform" Value="scale(1.02)"/>
    </Style>

    <!-- 登录按钮按下效果 -->
    <Style Selector="Button.LoginButton:pressed">
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

    <!-- 登录按钮禁用状态 -->
    <Style Selector="Button.LoginButton:disabled">
        <Setter Property="Opacity" Value="0.6"/>
    </Style>

    <!-- 取消按钮样式 -->
    <Style Selector="Button.CancelButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Height" Value="45"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- 取消按钮悬停效果 -->
    <Style Selector="Button.CancelButton:pointerover">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 关闭按钮样式 -->
    <Style Selector="Button.CloseButton">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- 关闭按钮悬停效果 -->
    <Style Selector="Button.CloseButton:pointerover">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FF6B6B" Opacity="0.8"/>
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransform" Value="rotate(90deg)"/>
    </Style>

    <!-- 关闭按钮按下效果 -->
    <Style Selector="Button.CloseButton:pressed">
        <Setter Property="RenderTransform" Value="scale(0.9) rotate(90deg)"/>
    </Style>

</Styles>
