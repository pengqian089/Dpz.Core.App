<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 深色主题颜色 -->
    <Style>
        <Style.Resources>
            <SolidColorBrush x:Key="DarkBackground">#0F172A</SolidColorBrush>
            <SolidColorBrush x:Key="CardBackground">#1E293B</SolidColorBrush>
            <SolidColorBrush x:Key="SidebarBackground">#1E293B</SolidColorBrush>
            <SolidColorBrush x:Key="PrimaryBlue">#3B82F6</SolidColorBrush>
            <SolidColorBrush x:Key="PrimaryPurple">#8B5CF6</SolidColorBrush>
            <SolidColorBrush x:Key="AccentOrange">#F59E0B</SolidColorBrush>
            <SolidColorBrush x:Key="TextPrimary">#F1F5F9</SolidColorBrush>
            <SolidColorBrush x:Key="TextSecondary">#94A3B8</SolidColorBrush>
            <SolidColorBrush x:Key="BorderColor">#334155</SolidColorBrush>
        </Style.Resources>
    </Style>

    <!-- 统计卡片样式 -->
    <Style Selector="Border.StatCard">
        <Setter Property="Background" Value="#1E40AF"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="8"/>
    </Style>

    <!-- 内容卡片样式 -->
    <Style Selector="Border.ContentCard">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- 标题文本样式 -->
    <Style Selector="TextBlock.CardTitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- 数值文本样式 -->
    <Style Selector="TextBlock.StatValue">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- 标签文本样式 -->
    <Style Selector="TextBlock.StatLabel">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#E0E7FF"/>
        <Setter Property="Opacity" Value="0.9"/>
    </Style>

    <!-- 侧边栏菜单项样式 -->
    <Style Selector="Button.MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style Selector="Button.MenuItem:pointerover">
        <Setter Property="Background" Value="#334155"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style Selector="Button.MenuItem:pressed">
        <Setter Property="Background" Value="#475569"/>
    </Style>

    <!-- 操作按钮样式 -->
    <Style Selector="Button.ActionButton">
        <Setter Property="Background" Value="#1E40AF"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <Style Selector="Button.ActionButton:pointerover">
        <Setter Property="Background" Value="#1E3A8A"/>
    </Style>

    <Style Selector="Button.ActionButton:pressed">
        <Setter Property="Background" Value="#1E3A70"/>
    </Style>

</Styles>
